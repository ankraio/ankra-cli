# Import must target a second, provider-created Kapsule cluster. It must not
# point at the cluster created from kapsule-create.yaml.example. See:
# https://github.com/ankraio/cluster/blob/main/docs/providers/scaleway.md
KAPSULE_IMPORT_CREDENTIAL_ID=11111111-2222-4333-8444-555555555555
KAPSULE_IMPORT_PROVIDER_CLUSTER_ID=regions/fr-par/clusters/replace-with-separate-provider-cluster-id
KAPSULE_IMPORT_NAME=systest-kapsule-imported

# Post-delete verification for the Ankra-created fixture.
KAPSULE_CREATE_CREDENTIAL_ID=11111111-2222-4333-8444-555555555555
KAPSULE_ORPHAN_VERIFY_SCRIPT=/absolute/path/to/verify-scaleway-tagged-orphans
